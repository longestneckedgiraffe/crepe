---
import Layout from "../layouts/Layout.astro";
---

<Layout hideDefaultContent={true}>
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-6 sm:gap-8 w-full max-w-md px-4 sm:px-8">
    <a href="mailto:contact@ridhwanzaman.me" class="contact-link text-[#878b89] text-[1rem] sm:text-[1.1rem] font-light tracking-[-0.02em] no-underline transition-colors duration-300">
      contact@ridhwanzaman.me
    </a>
  </div>
</Layout>

<style>
  @media (hover: hover) and (pointer: fine) {
    .contact-link:hover {
      color: white;
    }
  }
</style>
